fine_min(d16_k2_dd_2, 1000000).
fine_max(d16_k2_dd_2, 2000000).
original_vi_text(d16_k2_dd_2, "sử dụng chứng nhận đăng ký xe (hoặc bản sao chứng nhận đăng ký xe có chứng thực kèm theo bản gốc giấy biên nhận của tổ chức tín dụng, chi nhánh ngân hàng nước ngoài trong trường hợp tổ chức tín dụng, chi nhánh ngân hàng nước ngoài giữ bản gốc chứng nhận đăng ký xe) không đúng số khung, số động cơ (số máy) của xe (kể cả rơ moóc).").
rule(d16_k3).
rule_type(d16_k3, confiscation).
article(d16_k3, 16).
clause(d16_k3, 3).
point(d16_k3, "").
subject(d16_k3, specialized_vehicle_driver).
action(d16_k3, drive_illegally_manufactured_assembled_or_modified_specialized_vehicle).
original_vi_text(d16_k3, "Tịch thu phương tiện đối với hành vi điều khiển xe máy chuyên dùng sản xuất, lắp ráp hoặc cải tạo trái quy định tham gia giao thông.").
rule(d16_k4_a).
rule_type(d16_k4_a, supplementary_penalty).
article(d16_k4_a, 16).
clause(d16_k4_a, 4).
point(d16_k4_a, "a").
subject(d16_k4_a, specialized_vehicle_driver).
action(d16_k4_a, confiscate_license_plate_for_clause_2_d).
original_vi_text(d16_k4_a, "Thực hiện hành vi quy định tại điểm d khoản 2 Điều này bị tịch thu biển số xe.").
rule(d16_k4_b).
rule_type(d16_k4_b, supplementary_penalty).
article(d16_k4_b, 16).
clause(d16_k4_b, 4).
point(d16_k4_b, "b").
subject(d16_k4_b, specialized_vehicle_driver).
action(d16_k4_b, confiscate_vehicle_if_no_proof_of_origin_for_clause_2_c_dd).
original_vi_text(d16_k4_b, "Thực hiện hành vi quy định tại điểm c, điểm đ khoản 2 Điều này trong trường hợp không có chứng nhận đăng ký xe (hoặc bản sao chứng nhận đăng ký xe có chứng thực kèm theo bản gốc giấy biên nhận của tổ chức tín dụng, chi nhánh ngân hàng nước ngoài trong trường hợp tổ chức tín dụng, chi nhánh ngân hàng nước ngoài giữ bản gốc chứng nhận đăng ký xe) hoặc sử dụng chứng nhận đăng ký xe (hoặc bản sao chứng nhận đăng ký xe có chứng thực kèm theo bản gốc giấy biên nhận của tổ chức tín dụng, chi nhánh ngân hàng nước ngoài trong trường hợp tổ chức tín dụng, chi nhánh ngân hàng nước ngoài giữ bản gốc chứng nhận đăng ký xe) không do cơ quan có thẩm quyền cấp, không đúng số khung, số động cơ (số máy) của xe hoặc bị tẩy xóa (kể cả rơ moóc) mà không chứng minh được nguồn gốc xuất xứ của phương tiện (không có giấy tờ, chứng nhận nguồn gốc xe, chứng nhận quyền sở hữu hợp pháp) thì bị tịch thu phương tiện.").
rule(d16_k5_a).
rule_type(d16_k5_a, remedial_measure).
article(d16_k5_a, 16).
clause(d16_k5_a, 5).
point(d16_k5_a, "a").
subject(d16_k5_a, specialized_vehicle_driver).
action(d16_k5_a, install_replace_or_restore_required_equipment_for_clause_1_b_c_d).
original_vi_text(d16_k5_a, "Thực hiện hành vi vi phạm quy định tại điểm b, điểm c, điểm d khoản 1 Điều này buộc lắp đầy đủ thiết bị hoặc thay thế thiết bị đủ tiêu chuẩn, quy chuẩn an toàn kỹ thuật hoặc khôi phục lại tính năng kỹ thuật của thiết bị theo quy định.").
rule(d16_k5_b).
rule_type(d16_k5_b, remedial_measure).
article(d16_k5_b, 16).
clause(d16_k5_b, 5).
point(d16_k5_b, "b").
subject(d16_k5_b, specialized_vehicle_driver).
action(d16_k5_b, surrender_altered_registration_or_inspection_documents).
original_vi_text(d16_k5_b, "Thực hiện hành vi quy định tại điểm đ khoản 2 Điều này buộc nộp lại chứng nhận đăng ký xe (hoặc bản sao chứng nhận đăng ký xe có chứng thực kèm theo bản gốc giấy biên nhận của tổ chức tín dụng, chi nhánh ngân hàng nước ngoài trong trường hợp tổ chức tín dụng, chi nhánh ngân hàng nước ngoài giữ bản gốc chứng nhận đăng ký xe), giấy chứng nhận, tem kiểm định an toàn kỹ thuật và bảo vệ môi trường bị tẩy xóa.").
rule(d16_k6).
rule_type(d16_k6, administrative_revocation).
article(d16_k6, 16).
clause(d16_k6, 6).
point(d16_k6, "").
subject(d16_k6, specialized_vehicle_driver).
action(d16_k6, revoke_invalid_or_unauthorized_registration_and_inspection_documents).
original_vi_text(d16_k6, "Ngoài việc bị áp dụng hình thức xử phạt, người điều khiển xe thực hiện hành vi quy định tại điểm đ khoản 2 Điều này bị thu hồi chứng nhận đăng ký xe (hoặc bản sao chứng nhận đăng ký xe có chứng thực kèm theo bản gốc giấy biên nhận của tổ chức tín dụng, chi nhánh ngân hàng nước ngoài trong trường hợp tổ chức tín dụng, chi nhánh ngân hàng nước ngoài giữ bản gốc chứng nhận đăng ký xe) không do cơ quan có thẩm quyền cấp hoặc không đúng số khung, số động cơ (số máy) của xe, giấy chứng nhận, tem kiểm định an toàn kỹ thuật và bảo vệ môi trường không do cơ quan có thẩm quyền cấp.").
% ===== END dieu_16_asp.lp =====

