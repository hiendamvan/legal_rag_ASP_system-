original_vi_text(d14_k3_b, "Điều khiển xe gắn biển số không đúng vị trí, không đúng quy cách theo quy định; gắn biển số không rõ chữ, số hoặc sử dụng chất liệu khác sơn, dán lên chữ, số của biển số xe; gắn biển số bị bẻ cong, che lấp, làm thay đổi chữ, số, màu sắc (của chữ, số, nền biển số xe), hình dạng, kích thước của biển số xe").
rule(d14_k4).
rule_type(d14_k4, confiscation).
article(d14_k4, 14).
clause(d14_k4, 4).
point(d14_k4, "").
subject(d14_k4, motorbike_driver).
action(d14_k4, drive_illegally_manufactured_or_assembled_vehicle).
original_vi_text(d14_k4, "Tịch thu phương tiện đối với hành vi điều khiển loại xe sản xuất, lắp ráp trái quy định tham gia giao thông.").
rule(d14_k5_a).
rule_type(d14_k5_a, supplementary_penalty).
article(d14_k5_a, 14).
clause(d14_k5_a, 5).
point(d14_k5_a, "a").
subject(d14_k5_a, motorbike_driver).
action(d14_k5_a, confiscate_license_plate_for_clause_3_a).
original_vi_text(d14_k5_a, "Thực hiện hành vi quy định tại điểm a khoản 3 Điều này bị tịch thu biển số xe").
rule(d14_k5_b).
rule_type(d14_k5_b, supplementary_penalty).
article(d14_k5_b, 14).
clause(d14_k5_b, 5).
point(d14_k5_b, "b").
subject(d14_k5_b, motorbike_driver).
action(d14_k5_b, confiscate_vehicle_if_no_proof_of_origin_for_clause_2_a_b).
original_vi_text(d14_k5_b, "Thực hiện hành vi quy định tại điểm a, điểm b khoản 2 Điều này trong trường hợp không có chứng nhận đăng ký xe (hoặc bản sao chứng nhận đăng ký xe có chứng thực kèm theo bản gốc giấy biên nhận của tổ chức tín dụng, chi nhánh ngân hàng nước ngoài trong trường hợp tổ chức tín dụng, chi nhánh ngân hàng nước ngoài giữ bản gốc chứng nhận đăng ký xe) hoặc sử dụng chứng nhận đăng ký xe (hoặc bản sao chứng nhận đăng ký xe có chứng thực kèm theo bản gốc giấy biên nhận của tổ chức tín dụng, chi nhánh ngân hàng nước ngoài trong trường hợp tổ chức tín dụng, chi nhánh ngân hàng nước ngoài giữ bản gốc chứng nhận đăng ký xe) không do cơ quan có thẩm quyền cấp, không đúng số khung, số động cơ (số máy) của xe hoặc bị tẩy xóa mà không chứng minh được nguồn gốc xuất xứ của phương tiện (không có giấy tờ, chứng nhận nguồn gốc xe, chứng nhận quyền sở hữu hợp pháp) thì bị tịch thu phương tiện.").
rule(d14_k6_a).
rule_type(d14_k6_a, remedial_measure).
article(d14_k6_a, 14).
clause(d14_k6_a, 6).
point(d14_k6_a, "a").
subject(d14_k6_a, motorbike_driver).
action(d14_k6_a, replace_or_restore_compliant_horn).
original_vi_text(d14_k6_a, "Thực hiện hành vi quy định tại điểm đ khoản 2 Điều này buộc thay thế thiết bị đủ tiêu chuẩn an toàn kỹ thuật hoặc khôi phục tính năng kỹ thuật của thiết bị theo quy định").
