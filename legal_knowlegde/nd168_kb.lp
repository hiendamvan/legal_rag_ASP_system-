clause(d14_k7, 7).
point(d14_k7, "").
subject(d14_k7, motorbike_driver).
action(d14_k7, revoke_invalid_or_unauthorized_registration).
original_vi_text(d14_k7, "Ngoài việc bị áp dụng hình thức xử phạt, người điều khiển xe thực hiện hành vi quy định tại điểm b khoản 2 Điều này bị thu hồi chứng nhận đăng ký xe (hoặc bản sao chứng nhận đăng ký xe có chứng thực kèm theo bản gốc giấy biên nhận của tổ chức tín dụng, chi nhánh ngân hàng nước ngoài trong trường hợp tổ chức tín dụng, chi nhánh ngân hàng nước ngoài giữ bản gốc chứng nhận đăng ký xe) không đúng số khung, số động cơ (số máy) của xe hoặc không do cơ quan có thẩm quyền cấp.").
rule(d14_k8_a).
rule_type(d14_k8_a, license_point_deduction).
article(d14_k8_a, 14).
clause(d14_k8_a, 8).
point(d14_k8_a, "a").
subject(d14_k8_a, motorbike_driver).
action(d14_k8_a, deduct_2_license_points_for_clause_2_a_b_c).
original_vi_text(d14_k8_a, "Thực hiện hành vi quy định tại điểm a, điểm b, điểm c khoản 2 Điều này bị trừ điểm giấy phép lái xe 02 điểm").
rule(d14_k8_b).
rule_type(d14_k8_b, license_point_deduction).
article(d14_k8_b, 14).
clause(d14_k8_b, 8).
point(d14_k8_b, "b").
subject(d14_k8_b, motorbike_driver).
action(d14_k8_b, deduct_6_license_points_for_clause_3).
original_vi_text(d14_k8_b, "Thực hiện hành vi quy định tại khoản 3 Điều này bị trừ điểm giấy phép lái xe 06 điểm").
